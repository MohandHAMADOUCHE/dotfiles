	name = Mohand HAMADOUCHE
	email = mohand.hamadouche.ext@orange.com

[init]
	defaultBranch = main

[pull]
	rebase = true

[rebase]
	autoStash = true

[push]
	autoSetupRemote = true

[branch]
	autoSetupMerge = true

[diff]
	algorithm = histogram

[merge]
	conflictstyle = zdiff3

[alias]
	lg = log --graph --decorate --oneline --all
	st = status -sb
	co = checkout
	br = branch -vv
	ci = commit
	last = log -1 HEAD
	amend = commit --amend --no-edit

[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
